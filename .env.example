# ── Core ──────────────────────────────────────────────────────────────────────
# Copy to .env and fill in values

JWT_SECRET=change-this-to-a-secure-random-string-minimum-32-characters
AUGUST_ADAPTER_URL=http://localhost:8000
DATA_DIR=/data
SPRING_PROFILES_ACTIVE=prod

# ── OSINT Adapter — AI Synthesis (required for any results) ───────────────────
# Get key at: https://openrouter.ai/keys
API_KEY_OPENROUTER=

# Optional: override the default model
# OSINT_MODEL=anthropic/claude-sonnet-4-5

# ── OSINT Adapter — Tier 1: Google Custom Search (free tier: 100 queries/day) ─
# Create a Custom Search Engine at: https://programmablesearchengine.google.com/
# Get API key at: https://console.cloud.google.com/ → Custom Search JSON API
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── OSINT Adapter — Tier 2: Proxycurl (LinkedIn enrichment) ──────────────────
# ~$0.01/search. Get key at: https://nubela.co/proxycurl/
PROXYCURL_API_KEY=

# ── OSINT Adapter — Tier 3: People Data Labs (comprehensive person data) ──────
# ~$0.10/search. Get key at: https://www.peopledatalabs.com/
PDL_API_KEY=

# ── OSINT Adapter — Tier 4: Hunter.io (email finding) ────────────────────────
# ~$0.01/search. Get key at: https://hunter.io/api-keys
HUNTER_API_KEY=

# ── Notifications (Priority 4) ────────────────────────────────────────────────
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@alumnibeacon.com

# ── Billing (Priority 6) ──────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
