# AlumniBeacon — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Core ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-minimum-32-characters
SPRING_PROFILES_ACTIVE=prod
DATA_DIR=/app/data
APP_BASE_URL=https://your-domain.com

# ── OSINT Engine ──────────────────────────────────────────────────────────────
# Options: python | agent-zero | hybrid
OSINT_ENGINE=python
AUGUST_ADAPTER_URL=http://localhost:8000
AGENT_ZERO_URL=http://localhost:80

# ── OSINT API Keys ────────────────────────────────────────────────────────────
# Required for AI synthesis (any results)
# Get key at: https://openrouter.ai/keys
API_KEY_OPENROUTER=

# Tier 1: Google Custom Search (free: 100 queries/day)
# Create CSE: https://programmablesearchengine.google.com/
# Get API key: https://console.cloud.google.com/ → Custom Search JSON API
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Tier 2: Proxycurl — LinkedIn enrichment (~$0.01/search)
# Get key: https://nubela.co/proxycurl/
PROXYCURL_API_KEY=

# Tier 3: People Data Labs — comprehensive person data (~$0.10/search)
# Get key: https://www.peopledatalabs.com/
PDL_API_KEY=

# Tier 4: Hunter.io — email finding (~$0.01/search)
# Get key: https://hunter.io/api-keys
HUNTER_API_KEY=

# ── Email Notifications (P4) ──────────────────────────────────────────────────
# Set MAIL_ENABLED=true once SMTP is configured
MAIL_ENABLED=false
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG.your-sendgrid-api-key
MAIL_FROM=noreply@alumnibeacon.com

# ── Stripe Billing (P6) ───────────────────────────────────────────────────────
# Get keys: https://dashboard.stripe.com/apikeys
# Get price IDs: https://dashboard.stripe.com/products
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_STARTER=price_your_starter_price_id
STRIPE_PRICE_ID_PROFESSIONAL=price_your_professional_price_id
